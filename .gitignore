# =============================================
# FOODATM FRUIT INVENTORY - .gitignore
# =============================================

# === Environment & Secrets (NEVER commit!) ===
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# === Node Modules ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === Build Output ===
dist/
dist-ssr/
build/

# === Vite Cache ===
.vite/
vite.config.js.timestamp-*

# === TypeScript ===
*.tsbuildinfo

# === OS Files ===
.DS_Store
Thumbs.db
desktop.ini

# === Editor & IDE ===
.vscode/
.idea/
*.swp
*.swo
*.orig

# === Logs ===
logs/
*.log

# === Coverage ===
coverage/
.nyc_output/
